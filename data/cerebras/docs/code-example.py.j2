import os
import requests

url = f"{os.getenv('SERVICE_BASE_URL')}/chat/completions"

headers = {
    "Authorization": f"Bearer {os.getenv('UNITYSVC_API_KEY')}",
    "Content-Type": "application/json"
}

data = {
    "model": "{{offering.name}}",  # replace if needed
    "messages": [
        {"role": "user", "content": "Say this is a test"}
    ]
}

response = requests.post(url, headers=headers, json=data)
response_json = response.json()

print("Status code:", response.status_code)
print("Full response:", response_json)

# Safely extract the content
if "choices" in response_json:
    print(response_json["choices"][0]["message"]["content"])
else:
    print("Error from API:", response_json.get("error") or response_json)